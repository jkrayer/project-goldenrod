{
  "name": "project_goldenrod",
  "version": "0.1.0",
  "description": "A theater-of-the-mind VTT",
  "main": "index.js",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared",
    "tools"
  ],
  "scripts": {
    "prepare": "husky",
    "test": "npm run --workspaces test",
    "lint": "npm run --workspaces lint",
    "format": "prettier --write .",
    "dev:tools": "npm run -w tools dev",
    "build:tools": "npm run -w shared build && npm run -w tools build",
    "build:tools:prod": "npm run -w shared build && npm run -w tools build:prod",
    "lint:tools": "npm run -w tools lint",
    "preview:tools": "npm run -w tools preview",
    "serve:tools": "npm run -w tools preview -- --host 0.0.0.0 --port 4173"
  },
  "keywords": [],
  "author": "James Krayer <jameskrayer@yahoo.com>",
  "license": "MIT",
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "16.2.6",
    "prettier": "3.6.2"
  }
}
