    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-redux": "9.2.0",
    "react-router": "7.10.1"
  },
  "devDependencies": {
    "@eslint/js": "9.36.0",
    "@types/node": "24.6.0",
    "@types/ramda": "0.31.1",
    "@types/react": "19.1.16",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.4",
    "autoprefixer": "10.4.22",
